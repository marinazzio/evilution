#!/usr/bin/env ruby
# frozen_string_literal: true

# Throwaway dogfood entrypoint (EV-yyd8). Boots the renamed snapshot runtime
# (tmp/evilution-runtime/) against the subject lib/, so mutation `eval` only
# clobbers Evilution::* (subject) while EvilutionRuntime::* drives the run.

$stdout.sync = true
$stderr.sync = true

# Pin the locked gemset regardless of how this entrypoint is invoked. Run
# directly (script/run_self_baseline spawns it without `bundle exec`), bare
# RubyGems would activate the newest installed gem of each dependency — e.g.
# diff-lcs 2.0.0, which evilution loads early and which then conflicts with
# rspec-expectations' `diff-lcs < 2.0` pin, breaking every worker's spec load.
require "bundler/setup"

snapshot = File.expand_path("../tmp/evilution-runtime", __dir__)
abort "snapshot missing — run script/build_runtime_snapshot" unless File.directory?(File.join(snapshot, "lib"))

$LOAD_PATH.unshift(File.expand_path("../lib", __dir__)) # subject Evilution::*
$LOAD_PATH.unshift(File.join(snapshot, "lib")) # runtime EvilutionRuntime::* (first)

require "evilution_runtime"
# Pre-load subject namespace so mutation `eval` in fork children can reopen
# Evilution::* classes (the eval expects them to exist). Children inherit this
# load via fork; eval rewrites methods on the subject side only — runtime stays
# in EvilutionRuntime::*.
require "evilution"

exit EvilutionRuntime::CLI.new(ARGV).call
